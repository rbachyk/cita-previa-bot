# Telegram bot credentials
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Browser settings
BROWSER_HEADLESS=false   # set to true for --monitor / --check
BROWSER_SLOW_MO=50

# SQLite DB path (relative to project root)
DB_PATH=data/cita_previa.db

# Discovery output directory
DISCOVERY_DIR=data/discovery

# ── Checker / monitor settings ────────────────────────────────────────────────
# Province: value from the #form select on the index page
# (discovered: Alicante = /icpco/citar?p=3&locale=es)
PROVINCE_URL_PATH=/icpco/citar?p=3&locale=es

# Office: value from #sede select (99 = any office in the province)
SEDE_VALUE=99

# Procedure: which tramiteGrupo select (0/1/2) and its option value
# (discovered: group 1, value 4112 = Tarjeta Ucrania TIE)
TRAMITE_GROUP_INDEX=1
TRAMITE_VALUE=4112

# Sub-procedure value — leave empty if not needed
SUBTRAMITE_VALUE=

# Applicant personal data (used to pass the identity validation step)
NIE=your_nie_here
NOMBRE=YOUR FULL NAME HERE

# Polling interval in seconds (default 5 minutes)
CHECK_INTERVAL_SECONDS=300

# How long to wait before re-alerting when slots stay open (default 1 hour)
ALERT_COOLDOWN_SECONDS=3600
